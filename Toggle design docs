<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>WS Video Reels — Design Guide</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
:root {
  --brown:#32302f; --cream:#fcfcfc; --soft:#686664; --bg:#f5f4f4;
  --gold:#c9a96e; --green:#1a7f4b; --red:#c0392b; --blue:#2980b9;
  --card-shadow:0 4px 16px rgba(0,0,0,0.08),0 0 0 0.75px rgba(0,0,0,0.06);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Inter',sans-serif;background:#edeae5;color:var(--brown);}

.nav{position:sticky;top:0;z-index:100;background:var(--brown);display:flex;overflow-x:auto;scrollbar-width:none;}
.nav::-webkit-scrollbar{display:none;}
.nav-btn{padding:14px 18px;font-size:11px;font-weight:700;color:rgba(255,255,255,0.5);white-space:nowrap;cursor:pointer;border:none;border-bottom:2px solid transparent;background:none;transition:all .2s;}
.nav-btn:hover,.nav-btn.active{color:white;border-bottom-color:var(--gold);}

.section{display:none;padding:36px 24px;max-width:960px;margin:0 auto;}
.section.active{display:block;}
.sec-hd{margin-bottom:28px;}
.sec-hd h2{font-size:20px;font-weight:800;letter-spacing:-.3px;}
.sec-hd p{font-size:13px;color:var(--soft);margin-top:6px;line-height:1.6;}

.phone{width:190px;height:410px;background:#0a0a0a;border-radius:32px;border:5px solid #1c1c1c;overflow:hidden;position:relative;box-shadow:0 20px 50px rgba(0,0,0,.28);flex-shrink:0;}
.phone::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:66px;height:17px;background:#1c1c1c;border-radius:0 0 11px 11px;z-index:20;}
.phone-sm{width:155px;height:336px;border-radius:28px;border-width:4px;}
.phone-sm::before{width:54px;height:14px;}
.phonel{width:165px;height:356px;background:#fcfcfc;border-radius:30px;border:5px solid #1c1c1c;overflow:hidden;position:relative;box-shadow:0 20px 50px rgba(0,0,0,.18);flex-shrink:0;display:flex;flex-direction:column;}
.phonel::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:58px;height:15px;background:#1c1c1c;border-radius:0 0 10px 10px;z-index:20;}

.vbg{position:absolute;inset:0;background:linear-gradient(180deg,#1a1008 0%,#2a1f10 30%,#1a1618 60%,#0a0a0a 100%);}
.vtop{position:absolute;top:0;left:0;right:0;padding:21px 11px 7px;display:flex;justify-content:space-between;background:linear-gradient(180deg,rgba(0,0,0,.6),transparent);z-index:10;}
.ctrl{width:22px;height:22px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;color:white;}
.vbot{position:absolute;bottom:0;left:0;right:0;padding:8px 11px 0;background:linear-gradient(0deg,rgba(0,0,0,.88),transparent);z-index:10;}
.v-prog{height:2px;background:rgba(255,255,255,.2);border-radius:2px;margin-bottom:5px;}
.v-fill{height:100%;background:white;border-radius:2px;}
.v-head{font-size:11px;font-weight:700;color:white;line-height:1.2;}
.v-sub{font-size:8px;color:rgba(255,255,255,.7);margin-top:2px;}
.v-cta{background:var(--cream);color:var(--brown);font-size:9px;font-weight:700;text-align:center;padding:8px;border-radius:100px;margin-top:7px;}
.v-hi{height:16px;display:flex;align-items:center;justify-content:center;}
.v-hi-bar{width:50px;height:3px;background:rgba(255,255,255,.25);border-radius:100px;}
.sdots{position:absolute;right:5px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:3px;z-index:10;}
.sdot{width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,.25);}
.sdot.on{background:white;height:9px;border-radius:2px;}
.person{position:absolute;left:50%;top:14%;transform:translateX(-50%);width:80px;height:115px;}
.p-head{width:34px;height:34px;background:radial-gradient(circle at 40% 35%,#c8a880,#8a6840);border-radius:50%;margin:0 auto 3px;position:relative;}
.p-head::after{content:'';position:absolute;top:-5px;left:-4px;width:42px;height:22px;background:#2a1a0a;border-radius:50% 50% 0 0;}
.p-body{width:58px;height:74px;background:linear-gradient(180deg,#1a1a2e,#0f1520);border-radius:11px 11px 5px 5px;margin:0 auto;}
.mic{position:absolute;width:5px;height:5px;background:#e0c070;border-radius:50%;top:26px;right:18px;}
.lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--soft);text-align:center;margin-top:10px;}
.badge-pill{display:inline-block;font-size:9px;font-weight:700;padding:3px 9px;border-radius:100px;color:white;}

/* ── README TAB ── */
.readme-hero{background:var(--brown);border-radius:18px;padding:32px 28px;margin-bottom:28px;color:white;position:relative;overflow:hidden;}
.readme-hero::before{content:'';position:absolute;top:-40px;right:-40px;width:200px;height:200px;border-radius:50%;background:rgba(201,169,110,.08);pointer-events:none;}
.readme-hero::after{content:'';position:absolute;bottom:-60px;right:20px;width:140px;height:140px;border-radius:50%;background:rgba(201,169,110,.05);pointer-events:none;}
.readme-eyebrow{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--gold);margin-bottom:10px;}
.readme-hero h1{font-size:24px;font-weight:800;letter-spacing:-.4px;line-height:1.2;margin-bottom:8px;}
.readme-hero p{font-size:13px;color:rgba(255,255,255,.6);line-height:1.7;max-width:520px;}
.readme-meta{display:flex;gap:16px;margin-top:20px;flex-wrap:wrap;}
.readme-meta-item{display:flex;align-items:center;gap:6px;font-size:11px;color:rgba(255,255,255,.5);}
.readme-meta-item span{color:rgba(255,255,255,.8);font-weight:600;}

.readme-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-bottom:28px;}
.readme-card{background:white;border-radius:14px;padding:18px;box-shadow:var(--card-shadow);cursor:pointer;transition:transform .15s,box-shadow .15s;border-top:3px solid transparent;}
.readme-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.12);}
.readme-card-icon{font-size:22px;margin-bottom:10px;}
.readme-card-num{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--soft);margin-bottom:4px;}
.readme-card-title{font-size:13px;font-weight:700;margin-bottom:5px;}
.readme-card-desc{font-size:11px;color:var(--soft);line-height:1.5;}
.readme-card-audience{display:inline-block;font-size:9px;font-weight:700;padding:2px 7px;border-radius:100px;margin-top:8px;}

.readme-who{background:white;border-radius:14px;padding:20px;box-shadow:var(--card-shadow);margin-bottom:14px;}
.readme-who h3{font-size:13px;font-weight:700;margin-bottom:14px;}
.readme-who-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;}
.readme-who-item{background:var(--bg);border-radius:9px;padding:11px;}
.readme-who-item h4{font-size:11px;font-weight:700;margin-bottom:4px;}
.readme-who-item p{font-size:10px;color:var(--soft);line-height:1.5;}

.readme-flow{background:white;border-radius:14px;padding:20px;box-shadow:var(--card-shadow);}
.readme-flow h3{font-size:13px;font-weight:700;margin-bottom:14px;}
.readme-flow-row{display:flex;align-items:center;flex-wrap:wrap;gap:0;}
.readme-flow-step{background:var(--bg);border-radius:9px;padding:10px 13px;flex:1;min-width:110px;}
.readme-flow-step h5{font-size:10px;font-weight:700;margin-bottom:2px;}
.readme-flow-step p{font-size:9px;color:var(--soft);line-height:1.4;}
.readme-flow-arrow{color:var(--gold);font-size:18px;padding:0 6px;flex-shrink:0;}

/* ── SECTION 1 — TAP ZONES ── */
.v1-row{display:flex;align-items:flex-start;gap:32px;flex-wrap:wrap;}
.zones{position:absolute;inset:0;display:flex;top:18%;height:55%;}
.zone{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;}
.zone-l{border-right:1.5px dashed rgba(255,140,0,.45);background:rgba(255,140,0,.07);}
.zone-c{background:rgba(255,255,255,.03);}
.zone-r{border-left:1.5px dashed rgba(100,180,255,.45);background:rgba(100,180,255,.07);}
.zone-ico{font-size:16px;}
.zone-txt{font-size:7px;font-weight:700;color:rgba(255,255,255,.7);text-align:center;line-height:1.4;}
.legend-stack{display:flex;flex-direction:column;gap:12px;max-width:260px;}
.leg{background:white;border-radius:11px;padding:13px 15px;box-shadow:var(--card-shadow);}
.leg h4{font-size:12px;font-weight:700;margin-bottom:3px;}
.leg p{font-size:11px;color:var(--soft);line-height:1.5;}
.leg .tag{font-size:9px;font-family:monospace;background:var(--bg);padding:2px 5px;border-radius:3px;display:inline-block;margin-top:4px;color:var(--brown);}

/* ── SECTION 2 — SCREEN ZONES ── */
.v2-row{display:flex;align-items:flex-start;gap:28px;flex-wrap:wrap;}
.zband{position:absolute;left:0;right:0;display:flex;align-items:center;justify-content:center;}
.zb-t{top:0;height:25%;background:rgba(192,57,43,.18);border-bottom:1.5px dashed rgba(192,57,43,.5);z-index:5;}
.zb-m{top:25%;height:50%;background:rgba(26,127,75,.1);border-bottom:1.5px dashed rgba(26,127,75,.4);z-index:5;}
.zb-b{bottom:0;height:25%;background:rgba(41,128,185,.18);z-index:5;}
.zb-lbl{font-size:7px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;padding:2px 5px;border-radius:3px;}
.zb-t .zb-lbl{color:rgba(192,57,43,.95);background:rgba(192,57,43,.15);}
.zb-m .zb-lbl{color:rgba(26,127,75,.95);background:rgba(26,127,75,.15);}
.zb-b .zb-lbl{color:rgba(41,128,185,.95);background:rgba(41,128,185,.15);}
.specgrid{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-top:7px;}
.specitem{background:var(--bg);border-radius:5px;padding:5px 7px;}
.specitem .k{font-size:8px;color:var(--soft);font-weight:600;}
.specitem .v{font-size:10px;font-weight:700;margin-top:1px;}

/* ── SECTION 3 — COPY ── */
.v3-row{display:flex;gap:20px;justify-content:center;flex-wrap:wrap;}
.v3-col{display:flex;flex-direction:column;align-items:center;gap:10px;}
.copy-rules{background:white;border-radius:11px;padding:13px;box-shadow:var(--card-shadow);max-width:190px;}
.copy-rules h4{font-size:10px;font-weight:700;margin-bottom:7px;}
.cr{font-size:9px;color:var(--soft);padding:3px 0;border-bottom:1px solid var(--bg);line-height:1.4;}
.cr:last-child{border:none;}
.cr strong{color:var(--brown);}

/* ── SECTION 4 — CONTENT TIMING ── */
.timing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:32px;}
.timing-card{background:white;border-radius:16px;padding:20px;box-shadow:var(--card-shadow);position:relative;overflow:hidden;}
.timing-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;}
.timing-card.quick::before{background:linear-gradient(to right,#e67e22,#f39c12);}
.timing-card.gtm::before{background:linear-gradient(to right,var(--blue),#5dade2);}
.timing-card.edu::before{background:linear-gradient(to right,var(--green),#58d68d);}
.timing-card.personal::before{background:linear-gradient(to right,#826f8b,#bf8f85);}
.timing-badge{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.7px;padding:4px 10px;border-radius:100px;margin-bottom:12px;}
.timing-card.quick .timing-badge{background:rgba(230,126,34,.12);color:#c87522;}
.timing-card.gtm .timing-badge{background:rgba(41,128,185,.12);color:#2471a3;}
.timing-card.edu .timing-badge{background:rgba(26,127,75,.12);color:#1a7f4b;}
.timing-card.personal .timing-badge{background:rgba(130,111,139,.12);color:#826f8b;}
.timing-dur{font-size:32px;font-weight:800;letter-spacing:-1px;line-height:1;}
.timing-card.quick .timing-dur{color:#e67e22;}
.timing-card.gtm .timing-dur{color:var(--blue);}
.timing-card.edu .timing-dur{color:var(--green);}
.timing-card.personal .timing-dur{color:#826f8b;}
.timing-unit{font-size:13px;font-weight:600;color:var(--soft);margin-left:2px;}
.timing-name{font-size:13px;font-weight:700;color:var(--brown);margin-top:8px;margin-bottom:4px;}
.timing-desc{font-size:11px;color:var(--soft);line-height:1.6;}
.timing-eg{margin-top:10px;background:var(--bg);border-radius:8px;padding:8px 10px;}
.timing-eg-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--soft);margin-bottom:5px;}
.timing-eg-item{font-size:10px;color:var(--brown);padding:2px 0;display:flex;align-items:center;gap:5px;}
.timing-eg-item::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.timing-card.quick .timing-eg-item::before{background:#e67e22;}
.timing-card.gtm .timing-eg-item::before{background:var(--blue);}
.timing-card.edu .timing-eg-item::before{background:var(--green);}
.timing-card.personal .timing-eg-item::before{background:#826f8b;}
.timeline-wrap{background:white;border-radius:16px;padding:24px;box-shadow:var(--card-shadow);margin-bottom:8px;}
.timeline-wrap h4{font-size:12px;font-weight:700;color:var(--soft);text-transform:uppercase;letter-spacing:.7px;margin-bottom:18px;}
.timeline-bar{position:relative;height:48px;background:var(--bg);border-radius:10px;overflow:hidden;display:flex;}
.tl-seg{display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:white;white-space:nowrap;padding:0 6px;}
.tl-seg.quick{background:linear-gradient(to right,#e67e22,#f39c12);flex:3;}
.tl-seg.gtm{background:linear-gradient(to right,var(--blue),#5dade2);flex:2;}
.tl-seg.edu{background:linear-gradient(to right,var(--green),#58d68d);flex:0.5;}
.tl-seg.personal{background:linear-gradient(to right,#826f8b,#bf8f85);flex:1;}
.tl-labels{display:flex;margin-top:7px;}
.tl-lbl{font-size:9px;color:var(--soft);text-align:center;}
.tl-lbl.quick{flex:3;}
.tl-lbl.gtm{flex:2;}
.tl-lbl.edu{flex:0.5;}
.tl-lbl.personal{flex:1;}

/* ── HANDOFF TAB ── */
.handoff-alert{background:linear-gradient(135deg,#1a3520,#2a5030);border-radius:14px;padding:20px 22px;margin-bottom:24px;display:flex;align-items:flex-start;gap:14px;}
.handoff-alert-icon{font-size:24px;flex-shrink:0;margin-top:2px;}
.handoff-alert h3{font-size:14px;font-weight:700;color:white;margin-bottom:4px;}
.handoff-alert p{font-size:12px;color:rgba(255,255,255,.6);line-height:1.6;}

.handoff-steps{display:flex;flex-direction:column;gap:14px;margin-bottom:28px;}
.handoff-step{background:white;border-radius:14px;padding:18px 20px;box-shadow:var(--card-shadow);display:flex;gap:16px;align-items:flex-start;}
.handoff-step-num{width:32px;height:32px;border-radius:50%;background:var(--brown);color:white;font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;}
.handoff-step-body h4{font-size:13px;font-weight:700;margin-bottom:5px;}
.handoff-step-body p{font-size:12px;color:var(--soft);line-height:1.6;margin-bottom:8px;}
.handoff-step-body p:last-child{margin-bottom:0;}
.spec-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;}
.spec-chip{background:var(--bg);border-radius:6px;padding:5px 9px;font-size:10px;font-weight:700;color:var(--brown);display:flex;align-items:center;gap:4px;}
.spec-chip .chip-label{color:var(--soft);font-weight:500;}

.handoff-naming{background:white;border-radius:14px;padding:18px 20px;box-shadow:var(--card-shadow);margin-bottom:14px;}
.handoff-naming h4{font-size:13px;font-weight:700;margin-bottom:12px;}
.naming-example{background:var(--bg);border-radius:9px;padding:13px 15px;font-family:monospace;font-size:12px;color:var(--brown);margin-bottom:10px;line-height:1.8;}
.naming-example .hi{background:rgba(201,169,110,.25);padding:1px 3px;border-radius:3px;color:#9a7030;}
.naming-parts{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:8px;}
.naming-part{background:var(--bg);border-radius:7px;padding:8px 10px;}
.naming-part .np-key{font-size:9px;font-weight:700;color:var(--gold);font-family:monospace;margin-bottom:2px;}
.naming-part .np-val{font-size:10px;color:var(--soft);}

.handoff-checklist{background:white;border-radius:14px;padding:18px 20px;box-shadow:var(--card-shadow);}
.handoff-checklist h4{font-size:13px;font-weight:700;margin-bottom:12px;}
.checklist-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;}
.checklist-item{display:flex;align-items:flex-start;gap:8px;background:var(--bg);border-radius:7px;padding:8px 10px;}
.ci-box{width:14px;height:14px;border-radius:3px;border:1.5px solid rgba(0,0,0,.15);flex-shrink:0;margin-top:1px;}
.ci-text{font-size:10px;color:var(--brown);line-height:1.4;}

/* ── SECTION 5 — CONTENT BLOCK MAP ── */
.v5-arch{background:#edeae5;border-radius:18px;padding:28px 20px;margin-bottom:32px;text-align:center;}
.v5-arch-title{font-size:18px;font-weight:800;letter-spacing:-.3px;margin-bottom:3px;}
.v5-arch-sub{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--soft);margin-bottom:24px;}
.v5-arch-row{display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;}
.v5-card{background:white;border-radius:14px;padding:18px;min-width:200px;text-align:left;box-shadow:0 4px 20px rgba(0,0,0,.07);}
.v5-card-title{font-size:13px;font-weight:700;margin-bottom:12px;}
.fld{margin-bottom:6px;}
.fld-key{font-size:8px;font-weight:700;letter-spacing:.5px;color:var(--soft);font-family:monospace;margin-bottom:2px;text-transform:uppercase;}
.fld-val{background:var(--bg);border-radius:4px;padding:4px 7px;font-size:9px;font-family:monospace;color:var(--brown);}
.iam-row{padding:6px 0;border-bottom:1px solid var(--bg);font-size:11px;color:var(--soft);}
.iam-row:last-child{border:none;}
.iam-note{background:var(--bg);border-radius:7px;padding:9px 11px;font-size:9px;font-family:monospace;color:var(--soft);line-height:1.7;margin-top:10px;}
.v5-map-row{display:flex;align-items:center;justify-content:center;gap:20px;flex-wrap:wrap;}
.v5-fields{display:flex;flex-direction:column;gap:5px;}
.v5-field{background:white;border-radius:7px;padding:7px 11px;box-shadow:var(--card-shadow);display:flex;align-items:center;gap:8px;}
.v5-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.v5-key{font-size:10px;font-family:monospace;font-weight:700;min-width:90px;}
.v5-val{font-size:9px;color:var(--soft);font-family:monospace;}
.v5-legend{display:flex;flex-direction:column;gap:7px;max-width:190px;}
.v5-leg-item{display:flex;align-items:flex-start;gap:7px;background:white;border-radius:7px;padding:7px 10px;box-shadow:var(--card-shadow);}
.v5-leg-dot{width:9px;height:9px;border-radius:3px;flex-shrink:0;margin-top:2px;}

/* ── SECTION 6 — USER JOURNEY ── */
.j-section{margin-bottom:44px;}
.j-title{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:var(--soft);margin-bottom:18px;display:flex;align-items:center;gap:10px;}
.j-title::after{content:'';flex:1;height:1px;background:rgba(0,0,0,.08);}
.j-row{display:flex;align-items:flex-start;overflow-x:auto;padding-bottom:8px;gap:0;}
.j-step{display:flex;flex-direction:column;align-items:center;gap:8px;flex-shrink:0;}
.j-con{width:52px;margin-top:50px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:3px;}
.j-line{height:1.5px;width:100%;background:linear-gradient(to right,var(--gold),#b8956a);}
.j-arrow{color:var(--gold);font-size:15px;margin-top:-6px;}
.j-clabel{font-size:8px;font-weight:700;color:var(--soft);text-align:center;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap;}
.j-step-num{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:white;flex-shrink:0;}
.j-step-header{display:flex;align-items:center;gap:5px;}
.j-step-name{font-size:10px;font-weight:700;}
